# Copy to terraform.tfvars and fill in. terraform.tfvars is git-ignored.

# --- Azure auth ---------------------------------------------------------------
subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
# Optional service-principal auth. Leave both empty to use `az login` /
# ARM_CLIENT_ID + ARM_CLIENT_SECRET environment variables instead.
# azure_client_id     = ""
# azure_client_secret = ""

# --- Resource group (you bring your own; this module adopts it) ---------------
resource_group_name = "my-cielara-rg"
location            = "eastus2" # must match the resource group's region

# --- Ownership / naming -------------------------------------------------------
# Optional: tags the network with your Cielara client ID for identification.
# Leave unset if you don't have one yet.
# cielara_client_id = "<client id Cielara gave you>"
# name_prefix       = "cielara"

# --- Network sizing -----------------------------------------------------------
# Default is 10.2.0.0/20 (disjoint from Cielara's 10.1.0.0/16 service CIDR).
# vnet_cidr = "10.2.0.0/20"
